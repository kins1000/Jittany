{
  "name": "GameScore",
  "type": "object",
  "properties": {
    "game_id": {
      "type": "string",
      "description": "Reference to the game"
    },
    "team_id": {
      "type": "string",
      "description": "Reference to the team"
    },
    "points": {
      "type": "number",
      "default": 0,
      "description": "Points earned in this game"
    }
  },
  "required": [
    "game_id",
    "team_id"
  ]
}